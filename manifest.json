{
  "manifest_version": 3,
  "name": "Better PiP for YouTube",
  "description": "A better Picture-in-Picture extension optimized exclusively for YouTube. Alt+P to activate.",
  "version": "1.1",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://www.youtube.com/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Open Better PiP"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "Open Picture-in-Picture"
    }
  },
  "icons": {
    "128": "icon128.png"
  }
}